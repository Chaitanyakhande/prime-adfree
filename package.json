{
"name": "tizenbrew-primevideo-adfree",
"version": "1.0.1",
"description": "An ad-free, auto-skipping, and UX-enhancing module for Amazon Prime Video on Samsung Tizen TVs.",
"packageType": "mods",
"appName": "Prime Video Ad Free",
"websiteURL": "https://www.primevideo.com/storefront",
"main": "index.js",
"evaluateScriptOnDocumentStart": true,
"keys": [
"MediaPlayPause",
"MediaPlay",
"MediaPause",
"MediaStop",
"MediaFastForward",
"MediaRewind",
"MediaTrackNext",
"MediaTrackPrevious"
]
}
